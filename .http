### POST - Crear pedido
POST {{baseUrl}}/api/v1/pedidos
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombre": "Alan Josué Zamarrón Ortiz",
  "telefono": "4181234567",
  "direccion": "Calle Principal #456, Dolores Hidalgo, Gto",
  "fecha_solicitud": "2026-03-18T00:00:00.000Z",
  "fecha_envio": "2026-03-20T00:00:00.000Z",
  "total": 150,
  "pagado": ["NO PAGADO"],
  "comentario": "Pedido de prueba"
}

